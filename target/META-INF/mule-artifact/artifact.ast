pplication/json\n---\n{\n \"flowName\": \"scheduler-tcdp-orchestration-main-flow End\",\n \"status\": \"Processed successfully....\",\n \"tracePoint\": \"END\",\n \"timestamp\": now()\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/when\u003e\r\n\u003cotherwise\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log No Data Found\" doc:id\u003d\"a9a374b2-f9d2-42d0-866f-1a33685f4b62\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"scheduler-tcdp-orchestration-main-flow End\",\n \"status\": \"No Data\",\n \"tracePoint\": \"End\",\n \"timestamp\": now()\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/otherwise\u003e\r\n\u003c/choice\u003e\r\n\u003cerror-handler ref\u003d\"global-error-handler\"\u003e\u003c/error-handler\u003e\r\n\u003c/flow\u003e","startColumn":2,"startLine":9},"groupModelName":"General","modelName":"initialState","value":{"aString":"started"},"defaultValue":true},{"groupModelName":"General","modelName":"maxConcurrency","value":{},"defaultValue":true},{"groupModelName":"Business Events","modelName":"enableDefaultEvents","value":{"aBoolean":false},"defaultValue":true}],"componentId":"scheduler-tcdp-orchestration-main-flow","extensionModel":{"name":"mule"},"modelName":"flow","modelType":"CONSTRUCT","annotations":{"{http://www.mulesoft.org/schema/mule/documentation}id":"277176d5-18d6-4fe1-8c76-f0a39d4861eb"}},{"directChildren":[{"directChildren":[],"componentType":"OPERATION","identifier":{"name":"logger","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"location":{"name":"common-http-request-flow","parts":[{"partPath":"common-http-request-flow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"common.xml","line":9,"column":2},{"partPath":"processors"},{"partPath":"0","partIdentifier":{"identifier":{"name":"logger","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":