.Integer","value":101},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":102}},"sourceCode":"\u003cflow name\u003d\"scheduler-tcdp-orchestration-main-flow\" doc:id\u003d\"277176d5-18d6-4fe1-8c76-f0a39d4861eb\"\u003e\r\n\u003cscheduler doc:name\u003d\"Job run every one hour\" doc:id\u003d\"4bbb7233-294d-4d95-959d-8aa0d6d91838\"\u003e\r\n\u003cscheduling-strategy\u003e\r\n\u003ccron expression\u003d\"${scheduler.frequency}\" timeZone\u003d\"${scheduler.timezone}\"\u003e\u003c/cron\u003e\r\n\u003c/scheduling-strategy\u003e\r\n\u003c/scheduler\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Start Main Log\" doc:id\u003d\"66a88474-ae4b-45c1-83c4-6d6867690123\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"scheduler-tcdp-orchestration-main-flow started\",\n \"tracePoint\": \"START\",\n \"timestamp\": now()\n}]\"\u003e\u003c/logger\u003e\r\n\u003ctry doc:name\u003d\"Try\" doc:id\u003d\"265f6fd6-bb1e-48f7-9f5b-7e666ca7ff40\"\u003e\r\n\u003cos:retrieve doc:name\u003d\"Retrieve\" doc:id\u003d\"bae6c1f0-57c3-4253-9258-9e1c5240af11\" key\u003d\"lastProcessedTimeStamp\" objectStore\u003d\"Watermark_Object_Store\" target\u003d\"lastProcessedTimeStamp\"\u003e\u003c/os:retrieve\u003e\r\n\u003cerror-handler\u003e\r\n\u003con-error-continue enableNotifications\u003d\"true\" logException\u003d\"true\" doc:name\u003d\"On Error Continue\" doc:id\u003d\"a30c3699-be7e-4acf-a588-36ddb68b1c93\"\u003e\r\n\u003cset-variable value\u003d\"#[null]\" doc:name\u003d\"Set Variable\" doc:id\u003d\"fa86648f-903f-4991-8cc4-7c1fd2f40288\" variableName\u003d\"lastProcessedTimeStamp\"\u003e\u003c/set-variable\u003e\r\n\u003c/on-error-continue\u003e\r\n\u003c/error-handler\u003e\r\n\u003c/try\u003e\r\n\u003cee:transform doc:name\u003d\"TCDP Details\" doc:id\u003d\"129c8821-de85-4ac5-9895-9c0122cd78ff\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\nif (vars.lastProcessedTimeStamp \u003d\u003d null)\n    \"SELECT\n        u.id AS \\\"user_id\\\",\n        jr.id AS job_role_id,\n        u.updated_at\n    FROM public.\\\"user\\\" u\n    JOIN public.job_role jr\n        ON jr.id \u003d u.job_role_id\n    WHERE u.updated_at \u003e\u003d NOW() - INTERVAL \u00276 years\u0027\n    ORDER BY u.updated_at DESC\"\nelse\n    \"SELECT\n        u.id AS \\\"user_id\\\",\n        jr.id AS job_role_id,\n        u.updated_at\n    FROM public.\\\"user\\\" u\n    JOIN public.job_role jr\n        ON jr.id \u003d u.job_role_id\n    WHERE u.updated_at \u003e \" ++ vars.lastProcessedTimeStamp ++ \"\n    ORDER BY u.updated_at DESC\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003cee:set-variable variableName\u003d\"httpDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/json\n---\n{\n\t\"host\": Mule::p(\u0027lms-tcdp.host\u0027),\n\t\"port\": Mule::p(\u0027lms-tcdp.port\u0027),\n\t\"basePath\": Mule::p(\u0027lms-tcdp.basePath\u0027),\n\t\"path\": Mule::p(\u0027lms-tcdp.path\u0027),\n\t\"method\": Mule::p(\u0027lms-tcdp.method\u0027),\n\t\"clientId\": Mule::p(\u0027lms-tcdp.clientId\u0027),\n\t\"clientSecret\": Mule::p(\u0027secure::lms-tcdp.clientSecret\u0027),\n\t\"query\": vars.query,\n\t\"protocol\" :  Mule::p(\u0027lms-tcdp.protocol\u0027)\n\t\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003cee:set-variable variableName\u003d\"reportname\"\u003e\u003c![CDATA[\"tcdp\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"common-http-request-flow\" doc:id\u003d\"4127c36f-3a7f-4378-876a-a76f21cedd46\" name\u003d\"common-http-request-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003cchoice doc:name\u003d\"Check if TCDP Data Exists\" doc:id\u003d\"5d0425f1-8404-4f79-95a6-53bd3c5163a4\"\u003e\r\n\u003cwhen expression\u003d\"#[!isEmpty(payload)]\"\u003e\r\n\u003cee:transform doc:name\u003d\"Databricks TCDP HTTP Details\" doc:id\u003d\"c5e63fd1