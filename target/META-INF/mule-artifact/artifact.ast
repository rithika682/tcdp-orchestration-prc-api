host\": Mule::p(\u0027lms-tcdp.host\u0027),\n\t\"port\": Mule::p(\u0027lms-tcdp.port\u0027),\n\t\"basePath\": Mule::p(\u0027lms-tcdp.basePath\u0027),\n\t\"path\": Mule::p(\u0027lms-tcdp.path\u0027),\n\t\"method\": Mule::p(\u0027lms-tcdp.method\u0027),\n\t\"clientId\": Mule::p(\u0027lms-tcdp.clientId\u0027),\n\t\"clientSecret\": Mule::p(\u0027secure::lms-tcdp.clientSecret\u0027),\n\t\"query\": vars.query,\n\t\"protocol\" :  Mule::p(\u0027lms-tcdp.protocol\u0027)\n\t\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003cee:set-variable variableName\u003d\"reportname\"\u003e\u003c![CDATA[\"tcdp\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e","startColumn":3,"startLine":25},"parameters":[{"groupModelName":"Message","modelName":"setPayload","value":{},"defaultValue":true},{"groupModelName":"Message","modelName":"setAttributes","value":{},"defaultValue":true},{"metadata":{"docAttributes":{},"endColumn":16,"endLine":69,"fileName":"implementation/tcdp-orchestration-prc-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/tcdp-orchestration-prc-api-v1-1.0.0-mule-application/src/main/mule/implementation/tcdp-orchestration-prc-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":4},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":16},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":28},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":28},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":69},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":1},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":18},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":69},"DECLARED_PREFIX":{"type":"java.lang.String","value":"ee"}},"sourceCode":"\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\nif (vars.lastProcessedTimeStam