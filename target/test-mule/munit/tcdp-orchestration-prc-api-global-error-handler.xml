    <!-- TEST 1: HTTP:CONNECTIVITY error is handled by global error handler -->
    <munit:test name="scheduler-tcdp-orchestration-http-connectivity-error-test"
        doc:id="6b9c4380-d0b5-4445-84cd-6fa211fc7b34"
        description="Global error handler should handle HTTP:CONNECTIVITY error from http:request"
        expectedErrorType="HTTP:CONNECTIVITY">

        <munit:behavior>
            <munit-tools:mock-when doc:name="Mock http:request - throw HTTP:CONNECTIVITY"
                doc:id="66012e2f-17b8-4026-b620-8d6dd8fe5c41"
                processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:id"
                        whereValue="3b0ebc5e-76bb-4ecf-aafd-81cd67a05855" />
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value='#[output application/json
---
readUrl("classpath://test-inputs/http-response.json")]' />
                    <munit-tools:error typeId="HTTP:CONNECTIVITY" />
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>

        <munit:execution>
            <flow-ref doc:name="Flow-ref to scheduler-tcdp-orchestration-main-flow"
                doc:id="3e315a6b-5f20-42cb-acfe-88d517afed6c"
                name="scheduler-tcdp-orchestration-main-flow" />
        </munit:execution>

        <munit:validation>
            <munit-tools:assert-that doc:name="Assert error response payload is not null"
                doc:id="4965764b-947b-4b19-99b1-bd385c47d4a7"
                is="#[MunitTools::notNullValue()]"
                expression="#[%dw 2.0
import * from dw::test::Asserts
---
payload must beObject()]" />
        </munit:validation>

    </munit:test>

